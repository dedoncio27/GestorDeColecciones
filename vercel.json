{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install && npm install --prefix server",
  "framework": "vite",
  "outputDirectory": "dist",
  "env": {
    "VITE_API_URL": "/api/collections"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
